NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@<aurora-cluster-endpoint>:5432/creapy?schema=public
JWT_SECRET=replace_me
JWT_EXPIRES_IN=30d
SKIP_EMAIL_VERIFICATION=true
MONETIZATION_MODE=LANDLORD_PAID
PAYMENT_PROVIDER=mock
PAYNOW_INTEGRATION_ID=your_integration_id
PAYNOW_INTEGRATION_KEY=your_integration_key
PAYNOW_RESULT_URL=https://<branch>.<appid>.amplifyapp.com/webhooks/payment # Must match your Amplify backend compute URL
PAYNOW_RETURN_URL=https://your-frontend.amplifyapp.com/payment-complete
LISTING_FEE_AMOUNT=5
TENANT_PREMIUM_AMOUNT=10

## Amazon SES
AWS_REGION=af-south-1
EMAIL_FROM=no-reply@yourdomain.com
APP_BASE_URL=http://localhost:3000

## Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=

## Amazon S3
S3_BUCKET=your-s3-bucket-name
S3_REGION=af-south-1
S3_PUBLIC_BASE_URL=https://your-s3-public-base-url
# Optional for local development when not using an IAM role
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

FRONTEND_URL=https://<branch>.<appid>.amplifyapp.com
